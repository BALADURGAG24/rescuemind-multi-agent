# RescueMind AI – Environment Variables
# Copy this file to .env and fill in your API keys

# ─── Google / Gemini ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FLASH_MODEL=gemini-1.5-flash
MAX_TOKENS=8192
TEMPERATURE=0.3

# ─── External APIs ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
RELIEFWEB_API_KEY=your_reliefweb_api_key_here   # Free: https://reliefweb.int/api

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///database/rescuemind.db

# ─── MCP Ports ────────────────────────────────────────────────────────────────
MCP_WEATHER_PORT=8001
MCP_SHELTER_PORT=8002
MCP_RESOURCE_PORT=8003
MCP_RELIEF_PORT=8004
MCP_MEDICAL_PORT=8005
MCP_CONTACT_PORT=8006

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
MAX_INPUT_LENGTH=2000

# ─── App ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEMO_MODE=true    # Set false when real API keys are available
